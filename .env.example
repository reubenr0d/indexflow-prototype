# =============================================================================
# snx-prototype — environment template
# =============================================================================
# Copy to `.env` at the repo root (gitignored). Used by:
#   - Foundry (`foundry.toml` interpolates ${VAR} for RPC / etherscan)
#   - `scripts/agent-runner.mjs` and `scripts/update-yahoo-finance-prices.js`
#     (both load `.env` and `.env.local` from the project root)
# Shell exports still override file values.
#
# Next.js public vars belong in `apps/web/` — see `apps/web/.env.example`.
# =============================================================================

# --- Foundry RPC (required for `forge script --rpc-url sepolia` etc.) ---
SEPOLIA_RPC_URL=
ARBITRUM_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
FUJI_RPC_URL=

# --- Contract verification (optional; CI may use placeholders) ---
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
SNOWTRACE_API_KEY=

# --- Deploy scripts (optional offline Yahoo seed; 8-decimal USD raw integer) ---
# SEED_PRICE_RAW=4500000000

# --- LLM (agent runner + web app docs chat) ---
# Used by: `npm run agent` / `npm run agent:run` (agent runner)
#          `apps/web` server route `/api/docs-chat` (AI docs assistant)
# For the web app, also set this in `apps/web/.env.local` (or Vercel env vars).
LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# AGENT_DRY_RUN=1
# AGENT_CONFIRM_WRITES=0
# AGENT_NON_INTERACTIVE_WRITE_EXECUTE=1
# AGENT_MAX_TURNS=20
# AGENT_MAX_TOOL_RESPONSE=6000
# AGENT_NETWORK=sepolia

# --- Vault Manager MCP (passed through from the runner / shell) ---
# Defaults match `apps/vault-manager-mcp/index.js` when unset.
# DEPLOYMENT_CONFIG=apps/web/src/config/sepolia-deployment.json
# RPC_URL=sepolia
# PRIVATE_KEY=

# Yahoo Finance MCP: no env vars.

# --- 0G Network (decentralized AI infrastructure) ---
# 0G Storage: Decentralized persistent memory for agents
# Get testnet tokens from https://faucet.0g.ai
# ZG_PRIVATE_KEY=           # Funded wallet for storage fees (can share with ZG_COMPUTE_PRIVATE_KEY)
# ZG_RPC_URL=https://evmrpc-testnet.0g.ai
# ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# ZG_KV_CLIENT_URL=http://3.101.147.150:6789
# ZG_STREAM_ID=             # Auto-generated if not set

# 0G Compute: Decentralized AI inference (replaces OpenAI when configured)
# Browse providers at https://compute-marketplace.0g.ai/inference
# ZG_COMPUTE_PROVIDER=0xf07240Efa67755B5311bc75784a061eDB47165Dd
# ZG_COMPUTE_MODEL=llama-3.3-70b-instruct
# ZG_COMPUTE_RPC_URL=https://evmrpc-testnet.0g.ai
# ZG_COMPUTE_PRIVATE_KEY=   # Wallet for compute payments (can share with ZG_PRIVATE_KEY)

# --- KeeperHub (reliable transaction execution) ---
# Get API key from https://app.keeperhub.com
# KEEPERHUB_API_KEY=
# KEEPERHUB_API_URL=https://app.keeperhub.com

# --- Oracle price updater (`npm run update-prices:sepolia`, etc.) ---
# Uses same DEPLOYMENT_CONFIG, RPC_URL, PRIVATE_KEY as above.
# DRY_RUN=1

# --- Subgraph manifest (`apps/subgraph/scripts/generate-manifest.js`) ---
# NETWORK=anvil

# --- Push worker (`apps/push-worker`, e.g. Cloud Run) ---
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT_EMAIL=mailto:ops@indexflow.app
# SUBGRAPH_URL=
# DISPATCH_AUTH_TOKEN=
# PORT=8080
# RESERVE_BREACH_COOLDOWN_MS=1800000
# ORACLE_STALE_THRESHOLD_SECONDS=2700
# LARGE_PNL_THRESHOLD_USD=5000
# OPEN_INTEREST_NEAR_CAP_BPS=9000

# --- GitHub Actions (repository secrets; not set in local .env) ---
# Vault agent: LLM_API_KEY, KEEPER_PRIVATE_KEY, SEPOLIA_RPC_URL; optional LLM_BASE_URL, LLM_MODEL
# Update prices: same KEEPER_PRIVATE_KEY + SEPOLIA_RPC_URL (see .github/workflows/update-prices.yml)
# Keeper cron: KEEPER_PRIVATE_KEY + SEPOLIA_RPC_URL required; optional FUJI_RPC_URL + ARBITRUM_SEPOLIA_RPC_URL (see .github/workflows/keeper.yml)
# E2E (test.yml): NEXT_PUBLIC_PRIVY_APP_ID, PRIVY_TEST_EMAIL, PRIVY_TEST_OTP
# Production deploy: GCP_*, VERCEL_TOKEN, push worker secrets — see .github/workflows/deploy-production.yml
# Vercel project env vars (set via `vercel env add` or dashboard, not GH secrets):
#   LLM_API_KEY (Production + Preview) — powers /api/docs-chat AI assistant
