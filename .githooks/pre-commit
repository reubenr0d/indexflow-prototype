#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"

echo "=== Pre-commit lint checks ==="

# 1. Solidity formatting (same as CI: forge fmt --check)
echo "Checking Solidity formatting..."
PATH="/Users/reuben/.foundry/bin:$PATH" forge fmt --check --root "$ROOT_DIR"

# 2. Web ESLint (same as CI: npm run lint:web)
echo "Running ESLint on web app..."
npm --prefix "$ROOT_DIR" run lint:web

echo "=== All lint checks passed ==="
