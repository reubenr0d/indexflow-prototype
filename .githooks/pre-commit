#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

SOL_FILES=()
while IFS= read -r file; do
  SOL_FILES+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.sol$' || true)

if [ "${#SOL_FILES[@]}" -gt 0 ]; then
  echo "Running forge fmt for staged Solidity files..."
  PATH="/Users/reuben/.foundry/bin:$PATH" forge fmt --root "$ROOT_DIR" "${SOL_FILES[@]}"
  echo "Re-staging Solidity files after formatting..."
  git add "${SOL_FILES[@]}"
fi

WEB_FILES=()
while IFS= read -r file; do
  WEB_FILES+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '^apps/web/.*\.(js|jsx|ts|tsx)$' || true)

if [ "${#WEB_FILES[@]}" -gt 0 ]; then
  WEB_REL_FILES=()
  for file in "${WEB_FILES[@]}"; do
    WEB_REL_FILES+=("${file#apps/web/}")
  done

  echo "Running ESLint validation for staged web files..."
  npm --prefix apps/web run lint -- "${WEB_REL_FILES[@]}"
fi
