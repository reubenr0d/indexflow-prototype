#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"

for p in "$HOME/.foundry/bin" "$HOME/.cargo/bin"; do
  [[ -d "$p" ]] && export PATH="$p:$PATH"
done

echo "=== Pre-commit lint checks ==="

if command -v forge &>/dev/null; then
  echo "Checking Solidity formatting..."
  forge fmt --check --root "$ROOT_DIR"
else
  echo "Skipping Solidity formatting (forge not found; CI will catch it)"
fi

echo "Running ESLint on web app..."
npm --prefix "$ROOT_DIR" run lint:web

echo "=== All lint checks passed ==="
