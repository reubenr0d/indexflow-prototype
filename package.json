{
  "name": "snx-prototype",
  "version": "1.0.0",
  "description": "Perp infrastructure via GMX v1 fork with oracle-priced basket vaults",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test",
    "test:v": "forge test -vvv",
    "test:e2e": "npm --prefix apps/web run test:e2e",
    "test:e2e:ci": "npm --prefix apps/web run test:e2e:ci",
    "lint:web": "npm --prefix apps/web run lint",
    "hooks:install": "git config core.hooksPath .githooks",
    "prepare": "npm run hooks:install",
    "anvil": "anvil",
    "deploy:local": "PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 forge script script/DeployLocal.s.sol:DeployLocal --rpc-url http://127.0.0.1:8545 --broadcast -vvv",
    "deploy:sepolia": "forge script script/DeploySepolia.s.sol:DeploySepolia --rpc-url sepolia --broadcast -vvv",
    "sync:local": "forge script script/SyncAllOraclePrices.s.sol:SyncAllOraclePrices --rpc-url local --broadcast",
    "sync:sepolia": "DEPLOYMENT_CONFIG=apps/web/src/config/sepolia-deployment.json forge script script/SyncAllOraclePrices.s.sol:SyncAllOraclePrices --rpc-url sepolia --broadcast",
    "submit-sync:local": "forge script script/SubmitAndSyncOraclePrices.s.sol:SubmitAndSyncOraclePrices --rpc-url local --broadcast",
    "submit-sync:sepolia": "DEPLOYMENT_CONFIG=apps/web/src/config/sepolia-deployment.json forge script script/SubmitAndSyncOraclePrices.s.sol:SubmitAndSyncOraclePrices --rpc-url sepolia --broadcast",
    "update-prices:sepolia": "DEPLOYMENT_CONFIG=apps/web/src/config/sepolia-deployment.json RPC_URL=sepolia node scripts/update-yahoo-finance-prices.js",
    "update-prices:sepolia:dry": "DRY_RUN=1 DEPLOYMENT_CONFIG=apps/web/src/config/sepolia-deployment.json RPC_URL=sepolia node scripts/update-yahoo-finance-prices.js",
    "update-prices:local": "PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 DEPLOYMENT_CONFIG=apps/web/src/config/local-deployment.json RPC_URL=http://127.0.0.1:8545 node scripts/update-yahoo-finance-prices.js",
    "update-prices:local:dry": "DRY_RUN=1 DEPLOYMENT_CONFIG=apps/web/src/config/local-deployment.json RPC_URL=http://127.0.0.1:8545 node scripts/update-yahoo-finance-prices.js",
    "local:up": "docker compose -f docker-compose.local.yml up -d --build",
    "local:down": "docker compose -f docker-compose.local.yml down -v",
    "local:logs": "docker compose -f docker-compose.local.yml logs -f"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.2.0",
    "yahoo-finance2": "^3.14.0"
  }
}
