{
  "name": "snx-prototype",
  "version": "1.0.0",
  "description": "Perp infrastructure via GMX v1 fork with oracle-priced basket vaults",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test",
    "test:v": "forge test -vvv",
    "test:e2e": "npm --prefix apps/web run test:e2e",
    "test:e2e:ci": "npm --prefix apps/web run test:e2e:ci",
    "lint:web": "npm --prefix apps/web run lint",
    "hooks:install": "git config core.hooksPath .githooks",
    "prepare": "npm run hooks:install",
    "anvil": "anvil",
    "deploy:local": "forge script script/DeployLocal.s.sol:DeployLocal --rpc-url http://127.0.0.1:8545 --broadcast -vvv",
    "deploy:sepolia": "forge script script/DeploySepolia.s.sol:DeploySepolia --rpc-url sepolia --broadcast -vvv",
    "sync:local": "forge script script/SyncAllOraclePrices.s.sol:SyncAllOraclePrices --rpc-url local --broadcast",
    "sync:sepolia": "DEPLOYMENT_CONFIG=apps/web/src/config/sepolia-deployment.json forge script script/SyncAllOraclePrices.s.sol:SyncAllOraclePrices --rpc-url sepolia --broadcast",
    "submit-sync:local": "forge script script/SubmitAndSyncOraclePrices.s.sol:SubmitAndSyncOraclePrices --rpc-url local --broadcast",
    "submit-sync:sepolia": "DEPLOYMENT_CONFIG=apps/web/src/config/sepolia-deployment.json forge script script/SubmitAndSyncOraclePrices.s.sol:SubmitAndSyncOraclePrices --rpc-url sepolia --broadcast"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.2.0"
  }
}
