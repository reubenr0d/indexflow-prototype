#!/usr/bin/env sh
set -eu

for p in "$HOME/.foundry/bin" "$HOME/.cargo/bin"; do
  [ -d "$p" ] && PATH="$p:$PATH"
done
export PATH

if command -v forge >/dev/null 2>&1; then
  forge fmt --check --root "$(git rev-parse --show-toplevel)"
else
  echo "husky: skipping forge fmt (not installed; CI will catch it)"
fi

npm run lint:web
